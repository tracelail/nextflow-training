// ============================================================
// Session 10 — nextflow.config
// ============================================================

manifest {
    name        = 'session10-scatter-gather'
    description = 'Nextflow Training Session 10: Splitting and Grouping'
    version     = '1.0.0'
    nextflowVersion = '>=25.04.0'
}

// Default process settings
process {
    // Use withLabel selectors for resource classes (nf-core style)
    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
        time   = '30.m'
    }
    withLabel: 'process_medium' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }
}

// Profiles — switch with: nextflow run ... -profile docker
profiles {
    standard {
        process.executor = 'local'
    }

    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        process.container      = 'ubuntu:22.04'
    }

    test {
        params.input = "${projectDir}/data/samplesheet.csv"
    }
}

// Output directory default
params {
    outdir = 'results'
}
