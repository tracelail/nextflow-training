// my_custom.config
// ─────────────────────────────────────────────────────────────────────────────
// Session 13 — Exercise 3 (Challenge)
// Custom configuration for nf-core/demo
//
// This file demonstrates how to customise an nf-core pipeline without
// touching any of its source code.
//
// Usage:
//   nextflow run nf-core/demo \
//       -r 1.1.0 \
//       -profile docker,test \
//       -c my_custom.config \
//       --outdir results_custom_config
//
// The -c flag tells Nextflow to merge this config with the pipeline's
// own nextflow.config. Your settings take precedence over the pipeline
// defaults, but the -profile settings still apply.
// ─────────────────────────────────────────────────────────────────────────────

process {

    // withName uses the FULLY QUALIFIED process name in the format:
    //   PIPELINE_NAME:WORKFLOW_NAME:PROCESS_NAME
    //
    // You can find the full names by running the pipeline once and looking
    // at the log output, or in conf/modules.config inside the pipeline.

    withName: 'NFCORE_DEMO:DEMO:FASTQC' {
        // ext.args is passed verbatim to the tool command inside the module.
        // These are legitimate FastQC flags:
        //   --quiet   suppress progress messages
        //   --threads 2   allow FastQC to use 2 threads internally
        ext.args = '--quiet --threads 2'

        // You can also override resource directives here:
        cpus   = 2
        memory = '2.GB'
    }

    withName: 'NFCORE_DEMO:DEMO:MULTIQC' {
        // Override the output file title in the MultiQC report
        ext.args = '--title "Session 13 Custom Run"'
    }

}

// You can also add or override params here:
params {
    // This would change the max resources the pipeline is allowed to use.
    // Useful on laptops.
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '1.h'
}
