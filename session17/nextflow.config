// ============================================================
// Session 17 — nextflow.config
// ============================================================
// KEY POINT: The plugins {} block is how nf-schema is loaded.
// Always pin the version so your pipeline is reproducible.
// Nextflow downloads the plugin automatically at runtime.
// ============================================================

plugins {
    id 'nf-schema@2.6.1'
}

// ============================================================
// Default parameter values
// These must match the params defined in nextflow_schema.json.
// If a param is listed here but NOT in the schema, nf-schema
// will warn about an "unrecognised parameter".
// ============================================================
params {
    // Required inputs (no defaults — user must provide them)
    input  = null
    outdir = null

    // Optional processing parameters
    suffix           = 'counted'
    min_word_length  = 3
    condition_filter = 'all'
    email = null
}

// ============================================================
// nf-schema validation configuration
// All validation settings live in the validation {} scope.
// Note: In older nf-validation (v1.x), these were params like
// params.validationFailUnrecognisedParams — that is now gone.
// ============================================================
validation {
    // Path to the pipeline parameter schema (default shown)
    parametersSchema = "nextflow_schema.json"

    // Suppress ANSI colour codes in validation output
    monochromeLogs = false

    // Control what happens with unrecognised params/headers
    // Options per field: skip | debug | info | warn | error
    logging {
        unrecognisedParams  = "warn"
        unrecognisedHeaders = "warn"
    }

    // Built-in help message (try: nextflow run main.nf --help)
    help {
        enabled           = true
        shortParameter    = "help"
        fullParameter     = "helpFull"
        showHiddenParameter = "showHidden"
        command           = "nextflow run main.nf --input samplesheet.csv --outdir results"
    }
}

// ============================================================
// Output directory for publishDir in processes
// ============================================================
params.outdir = params.outdir ?: 'results'
