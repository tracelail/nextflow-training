// ============================================================
// Session 18 Starter Pipeline — nextflow.config
// ============================================================

// ── VIOLATION in config: config setting referencing another setting
// Config settings cannot reference each other as variables in strict mode.
// Only params can be referenced.
// This violation will appear in Exercise 3 when NXF_SYNTAX_PARSER=v2.
//
// google.location = 'us-central1'
// google.batch.subnetwork = "regions/${google.location}/subnetworks/default"
//
// The above is commented out here but represents a common real-world pattern.

// ── NOTE: params.* assignments belong here in the config.
// Once you add the typed params{} block to main.nf (Exercise 4),
// you will remove the params.* defaults below (keeping only non-typed ones
// or values you still want the config to set).

params {
    // Core input/output — will be migrated to typed params{} block in main.nf
    input       = null
    outdir      = 'results'

    // Pipeline behaviour
    genome      = 'GRCh38'
    save_all    = false
    multiqc_title = ''

    // Resource caps
    max_memory = '16.GB'
    max_cpus   = 8
    max_time   = '24.h'
}

// ── Process defaults ─────────────────────────────────────────
process {
    cpus   = 1
    memory = '2.GB'
    time   = '30.m'

    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
        time   = '1.h'
    }

    withLabel: 'process_medium' {
        cpus   = 4
        memory = '8.GB'
        time   = '4.h'
    }

    withLabel: 'process_high' {
        cpus   = 8
        memory = '16.GB'
        time   = '16.h'
    }
}

// ── Profiles ─────────────────────────────────────────────────
profiles {
    test {
        params {
            input  = "${projectDir}/../../sample_data/samplesheet.csv"
            outdir = 'results_test'
        }
        process {
            cpus   = 1
            memory = '1.GB'
        }
    }

    docker {
        docker.enabled = true
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    conda {
        conda.enabled = true
    }
}

// ── Reporting ────────────────────────────────────────────────
dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/dag.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report.html"
}

timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
}
