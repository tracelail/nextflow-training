/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per-module options and publishing paths
    ─────────────────────────────────────────────────────────────────────────────────
    Available keys to override module options:
        ext.args            Additional arguments appended to the primary command.
        ext.args2           Secondary arguments (for modules that call 2 tools).
        ext.args3           Tertiary arguments (for modules that call 3 tools).
        ext.prefix          Override the output file name prefix (default: meta.id).
        ext.when            Boolean or closure — set to false to skip the process.
        publishDir          Override publishing path, mode, or saveAs filter.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // ──────────────────────────────────────────────────────────────────────────────
    // DEFAULT publishDir for ALL processes
    // ──────────────────────────────────────────────────────────────────────────────
    // This expression extracts the tool name from the fully-qualified process name.
    //
    // Example: process name = "NFCORE_GREETINGS:GREETINGS:SAY_HELLO"
    //   task.process.tokenize(':')    → ['NFCORE_GREETINGS', 'GREETINGS', 'SAY_HELLO']
    //   [-1]                          → 'SAY_HELLO'
    //   .tokenize('_')[0]             → 'SAY'
    //   .toLowerCase()                → 'say'
    //
    // This places outputs in results/say/ by default.
    // Override it in a withName block for specific processes (as done for SAY_HELLO below).
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ──────────────────────────────────────────────────────────────────────────────
    // SAY_HELLO
    // ──────────────────────────────────────────────────────────────────────────────
    withName: 'SAY_HELLO' {

        // ext.args is appended to the echo command inside the module.
        // The module reads: def args = task.ext.args ?: ''
        // Then uses:        echo "${greeting} from ${meta.id} ${args}"
        //
        // STATIC value — no braces needed:
        ext.args = '(nf-core training)'

        // DYNAMIC value example (uncomment to try):
        // A closure is required whenever you reference params.* or other
        // runtime values — otherwise they are evaluated at config parse time.
        // ext.args = { "(run: ${params.run_name ?: 'unnamed'})" }

        // Override the publishDir just for this process
        publishDir = [
            path: { "${params.outdir}/greetings" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    NOTES FOR LEARNERS
    ─────────────────────────────────────────────────────────────────────────────────
    Q: Why does the default publishDir path use a closure ({ })?
    A: Because params.outdir is not available until runtime. Closures delay evaluation.
       Plain strings like ext.args = '--quiet' are fine for static values. Dynamic
       values that reference params.* always need a closure.

    Q: Why is the withName selector quoted ('SAY_HELLO') in this file?
    A: Both quoted and unquoted work for simple names. Quotes are required when the
       selector contains special characters like * or : (for regex matching full paths).
       Quoting simple names is fine and more consistent.

    Q: Can I have multiple withName blocks?
    A: Yes. Add one block per process. The process name must match (or be a regex
       substring of) the fully-qualified name. When two selectors match the same
       process, both are applied — later blocks override earlier ones.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/
