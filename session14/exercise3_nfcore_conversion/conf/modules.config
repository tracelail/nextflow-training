/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per-module options and publishing paths
    ─────────────────────────────────────────────────────────────────────────────────
    This file is the central "control panel" for the greetings pipeline.
    No process arguments are hardcoded in the module files themselves.
    Everything flows through ext.args and publishDir here.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    // ─────────────────────────────────────────────────────────────────────────────
    // DEFAULT publishDir for all processes
    // ─────────────────────────────────────────────────────────────────────────────
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ─────────────────────────────────────────────────────────────────────────────
    // SAY_HELLO — Step 1: generate per-sample greeting files
    // ─────────────────────────────────────────────────────────────────────────────
    withName: 'SAY_HELLO' {
        ext.args   = ''    // no extra args for the echo command
        publishDir = [
            path: { "${params.outdir}/greetings" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ─────────────────────────────────────────────────────────────────────────────
    // CONVERT_UPPER — Step 2: uppercase the greeting files
    // ─────────────────────────────────────────────────────────────────────────────
    withName: 'CONVERT_UPPER' {
        // tr '[:lower:]' '[:upper:]' takes input from stdin (via <).
        // ext.args could be used to pass flags to tr if needed.
        // For now it is empty — no extra flags required.
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/upper" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ─────────────────────────────────────────────────────────────────────────────
    // COLLECT_RESULTS — Step 3: aggregate all uppercased files into one summary
    // ─────────────────────────────────────────────────────────────────────────────
    withName: 'COLLECT_RESULTS' {
        ext.args   = ''
        publishDir = [
            path: { "${params.outdir}/collected" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    INTERMEDIATE EXERCISE: Customise ext.args
    ─────────────────────────────────────────────────────────────────────────────────
    Try changing SAY_HELLO's ext.args:

        ext.args = '(processed by nf-core/greetings)'

    Re-run with -resume. The process re-executes because its command hash changed.
    The output files now contain the suffix. No module code was changed.

    CHALLENGE EXERCISE: Dynamic args with a closure
    ─────────────────────────────────────────────────────────────────────────────────
    Add a parameter 'run_label' to nextflow.config params block:
        run_label = 'training_run'

    Then change SAY_HELLO's ext.args to a closure:
        ext.args = { "(${params.run_label})" }

    Re-run with --run_label "my_custom_label".
    The label in each output file should change.
    Notice: without the closure braces { }, params.run_label would be
    evaluated at config parse time (before --run_label is processed),
    and you would always get the default value.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/
