/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
    ─────────────────────────────────────────────────────────────────────────────────
    Use: nextflow run main.nf -profile test --outdir results_test

    This profile is used by CI/CD to verify the pipeline runs end-to-end.
    It should run quickly (< 5 min) on a standard laptop.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources so the CI can run in a small environment
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '6.h'

    // Input data — the minimal 3-sample samplesheet
    input  = "${projectDir}/assets/samplesheet.csv"
    outdir = './results_test'
}
