/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/greetings Nextflow config file
    ─────────────────────────────────────────────────────────────────────────────────
    Default config options for all compute environments.
    Cluster-specific options should be set in a profile (see profiles block below).
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Global default params — each can be overridden on the CLI with --param_name value
params {

    // ─────────────────────────────────────────────────────────────────────────────
    // INPUT / OUTPUT
    // ─────────────────────────────────────────────────────────────────────────────
    input              = null                    // Path to samplesheet CSV
    outdir             = null                    // Output directory (required)
    publish_dir_mode   = 'copy'                  // How to publish: copy, symlink, link

    // ─────────────────────────────────────────────────────────────────────────────
    // PIPELINE BEHAVIOUR
    // ─────────────────────────────────────────────────────────────────────────────
    // run_label is an example of a custom pipeline parameter.
    // It is used in modules.config ext.args (in the challenge exercise).
    run_label          = 'training'

    // ─────────────────────────────────────────────────────────────────────────────
    // nf-schema / validation options
    // ─────────────────────────────────────────────────────────────────────────────
    validate_params    = true
    validationShowHiddenParams = false

    // ─────────────────────────────────────────────────────────────────────────────
    // BOILERPLATE — required by PIPELINE_INITIALISATION and PIPELINE_COMPLETION
    // ─────────────────────────────────────────────────────────────────────────────
    version            = false
    monochrome_logs    = false
    hook_url           = null
    email              = null
    email_on_fail      = null
    plaintext_email    = false
}

// ─────────────────────────────────────────────────────────────────────────────────
// NEXTFLOW CONFIGURATION
// ─────────────────────────────────────────────────────────────────────────────────

// Produce a detailed workflow execution summary report
dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/pipeline_report.html"
}
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/pipeline_timeline.html"
}
trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/pipeline_trace.txt"
}

manifest {
    name            = 'nf-core/greetings'
    author          = 'nf-core'
    homePage        = 'https://github.com/nf-core/greetings'
    description     = 'A training pipeline that generates and transforms greetings'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=25.04.0'    // '!' means fail if not satisfied
    version         = '1.0.0dev'
    doi             = ''
}

// ─────────────────────────────────────────────────────────────────────────────────
// LOAD BASE RESOURCES CONFIG
// ─────────────────────────────────────────────────────────────────────────────────
includeConfig 'conf/base.config'

// ─────────────────────────────────────────────────────────────────────────────────
// LOAD MODULES CONFIG (ext.args, ext.prefix, publishDir per process)
// ─────────────────────────────────────────────────────────────────────────────────
includeConfig 'conf/modules.config'

// ─────────────────────────────────────────────────────────────────────────────────
// PROFILES — switch between environments with -profile <name>
// ─────────────────────────────────────────────────────────────────────────────────
profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    test {
        includeConfig 'conf/test.config'
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
    }
    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
    }
}
