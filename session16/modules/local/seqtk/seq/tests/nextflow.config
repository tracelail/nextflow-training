// Test-specific configuration for SEQTK_SEQ nf-test tests.
// This file is picked up automatically by nf-test when running tests
// in this directory.  Use it to set ext.args or override params for tests.
conda.enabled = true
conda.cacheDir = "${HOME}/.conda/nextflow-cache"

process {
    withName: 'SEQTK_SEQ' {
        // ext.args is empty for the basic test — seqtk seq -a is always applied
        // by the module itself, so no additional args are needed here.
        ext.args = ''
    }
}
