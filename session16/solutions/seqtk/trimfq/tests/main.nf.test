nextflow_process {

    name "Test Process SEQTK_TRIMFQ"
    script "../main.nf"
    process "SEQTK_TRIMFQ"

    tag "modules"
    tag "modules_nfcore"
    tag "seqtk"
    tag "seqtk/trimfq"

    test("fastq single-end - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test', single_end: true ],
                    file("${projectDir}/../../../../../test_data/sample1.fastq",
                         checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
