// =============================================================================
// conf/modules.config
//
// This is where pipeline-level per-process configuration lives in nf-core
// pipelines.  Each process gets its own withName block for:
//   - ext.args  : extra CLI arguments passed through task.ext.args
//   - ext.prefix: output filename prefix (defaults to meta.id if not set)
//   - publishDir: where to copy final outputs
//
// Note: ext.args and ext.prefix use CLOSURES { } so they can reference the
// meta map dynamically.  Without closures, Nextflow evaluates them at parse
// time (before any channel data exists) and they silently produce wrong values.
// =============================================================================

process {

    withName: 'SEQTK_SEQ' {
        ext.args   = { '' }
        ext.prefix = { "${meta.id}" }

        publishDir = [
            path: { "${params.outdir}/seqtk/seq" },
            mode: 'copy',
            saveAs: { filename -> filename.endsWith('.fasta.gz') ? filename : null }
        ]
    }

    // When you complete the SEQTK_TRIMFQ exercise, uncomment and fill in:
    // withName: 'SEQTK_TRIMFQ' {
    //     ext.args   = { '' }
    //     ext.prefix = { "${meta.id}.trimmed" }
    //     publishDir = [
    //         path: { "${params.outdir}/seqtk/trimfq" },
    //         mode: 'copy'
    //     ]
    // }
}
