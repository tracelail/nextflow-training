// =============================================================================
// Session 16 nextflow.config
// =============================================================================

params {
    input  = "${projectDir}/assets/samplesheet.csv"
    outdir = "${launchDir}/results"
}

// Pull in per-process configuration (ext.args, publishDir, etc.)
includeConfig 'conf/modules.config'

// ----------------------------------------------------------------------------
// Profiles
// ----------------------------------------------------------------------------
profiles {

    conda {
        conda.enabled    = true
        docker.enabled   = false
        singularity.enabled = false
        // cache downloaded conda environments to avoid re-solving on every run
        conda.cacheDir   = "${HOME}/.conda/nextflow-cache"
    }

    docker {
        docker.enabled   = true
        conda.enabled    = false
        singularity.enabled = false
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
        docker.enabled         = false
    }

    // 'test' profile runs a quick smoke-test without real data processing
    test {
        params.input = "${projectDir}/assets/samplesheet.csv"
    }
}

// ----------------------------------------------------------------------------
// Execution defaults
// ----------------------------------------------------------------------------
process {
    cpus   = 1
    memory = '2.GB'
    time   = '30.m'

    // Resource labels used by nf-core modules
    withLabel: 'process_single' {
        cpus   = 1
        memory = '1.GB'
        time   = '15.m'
    }
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4.GB'
        time   = '30.m'
    }
}


