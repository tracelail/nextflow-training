// nextflow.config — Session 19
// Covers: workflow output mode, data lineage, Wave (conceptual), profiles

// ─── Workflow output settings ─────────────────────────────────────────────────
// Controls how files are placed in the output directory.
// Options: 'symlink' (default), 'copy', 'move', 'link', 'rellink', 'copyNoFollow'
// Change this to 'copy' for Exercise 1 step 4.
workflow.output.mode = 'symlink'

    // Lineage profile — enables data lineage tracking (Exercise 2)
    // Run with: nextflow run ex2_lineage.nf -profile lineage
    //
    // NOTE: lineage only tracks files published via the workflow output block.
    //       publishDir-published files do NOT generate lineage records.

    lineage {
        enabled = true
        // store.location = '.lineage'  // default; uncomment to customise
    }
// ─── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // Default profile — runs locally without containers
    standard {
        process.executor = 'local'
    }


    // Wave profile — on-demand container provisioning from Conda specs (conceptual)
    // Requires a Seqera Platform account for production use.
    // With wave.strategy = ['conda'] Nextflow reads each process's conda: directive
    // and asks Wave to build a container image automatically.
    //
    // wave {
    //     wave {
    //         enabled  = true
    //         strategy = ['conda']
    //         freeze   = false   // set true to persist images beyond 1 week
    //     }
    //     // tower {
    //     //     accessToken = '<your Seqera Platform token>'
    //     // }
    // }
}

// ─── Process defaults ─────────────────────────────────────────────────────────
process {
    errorStrategy = 'terminate'
}

// ─── Manifest ─────────────────────────────────────────────────────────────────
manifest {
    name        = 'session19-advanced-features'
    description = 'Nextflow training Session 19: workflow outputs, lineage, topic channels'
    version     = '1.0.0'
    nextflowVersion = '>=25.10.0'
}
