// =============================================================================
// Session 11 — nextflow.config
// Cache, Resume, and Debugging
// =============================================================================

// Default parameters — override from CLI with --param value
params {
    input     = "${launchDir}/data/samplesheet.csv"
    outdir    = "${launchDir}/results"
    max_retries = 1
}

// Default process settings
process {
    // Keep failed work directories so we can inspect them
    errorStrategy = 'terminate'
    maxRetries    = params.max_retries

    // Resource defaults — kept small for local training use
    cpus   = 1
    memory = '512.MB'
    time   = '10.m'
}

// Write an HTML execution report automatically
report {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_report.html"
}

// Write a timeline report
timeline {
    enabled = true
    overwrite = true
    file    = "${params.outdir}/pipeline_timeline.html"
}

// Execution trace — machine-readable TSV of every task
trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_trace.txt"
    // Include these fields in the trace
    fields    = 'task_id,name,status,exit,duration,realtime,cpus,memory,workdir'
}

// Profiles — switch between execution contexts with -profile <name>
profiles {

    // Default: local execution, no containers
    standard {
        process.executor = 'local'
    }

    // Debug profile: slow down maxForks so output is easier to follow
    debug {
        process {
            executor = 'local'
            maxForks = 1          // Run one task at a time (easier to read output)
            debug    = true       // Print task stdout to the terminal
            // cleanup  = false      // Keep work directories even on success
        }
        // Cache strategy that tolerates NFS timestamp issues
        // cache = 'lenient'
    }

    // Lenient cache profile: ignores file timestamps (useful on NFS or shared storage)
    lenient {
        process.cache = 'lenient'
    }
}
