/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per-module options and publishing results
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args            = Additional arguments appended to the tool command
        ext.args2           = Second set of args (for tools with multiple commands)
        ext.prefix          = File name prefix for output files
        ext.when            = Conditional: run this process only when true
----------------------------------------------------------------------------------------
*/

process {

    // ---------------------------------------------------------------------------------
    // FASTQC
    // ---------------------------------------------------------------------------------
    // ext.args is a CLOSURE (curly braces required) so it evaluates at runtime.
    // This lets you reference params, meta, and task variables.
    //
    // --quiet suppresses progress messages — useful in pipelines where they clutter logs.
    // ---------------------------------------------------------------------------------
    withName: 'FASTQC' {
        ext.args   = { '--quiet --noextract' }
        // ext.prefix lets you rename outputs. Uncomment to add a suffix:
        // ext.prefix = { "${meta.id}_fastqc" }
        ext.when = !params.skip_fastqc

        publishDir = [
            path: { "${params.outdir}/fastqc" },
            mode: params.publish_dir_mode,
            // Only publish the HTML reports to results; keep .zip files in work/
            pattern: "*.html"
        ]
    }

    // ---------------------------------------------------------------------------------
    // MULTIQC
    // ---------------------------------------------------------------------------------
    // MultiQC has no meta map, so ext.prefix is a plain string, not a closure.
    // ---------------------------------------------------------------------------------
    withName: 'MULTIQC' {
        ext.args   = { '' }
        ext.prefix = { 'multiqc' }

        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
