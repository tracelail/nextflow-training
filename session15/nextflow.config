/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    session15/nextflow.config
    nf-core modules: Installing and using community components
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// -------------------------------------------------------------------------------------
// Manifest setup — provided for download of nf-core modules
// -------------------------------------------------------------------------------------
manifest {
    name        = 'session15'
    description = 'Session 15 training pipeline - nf-core modules'
    version     = '0.1.0'
    nextflowVersion = '>=25.04.0'
}

wave {
    enabled = true
}
// -------------------------------------------------------------------------------------
// Pipeline parameters — override on the command line with --param value
// -------------------------------------------------------------------------------------
params {
    // Input / output
    input            = "${projectDir}/assets/samplesheet.csv"
    outdir           = "results"
    publish_dir_mode = 'copy'

    // MultiQC config (optional — leave null to use defaults)
    multiqc_config   = null
    multiqc_title    = null

    // Resource limits — prevents over-requesting on a laptop
    max_cpus         = 4
    max_memory       = '8.GB'
    max_time         = '2.h'
}

// -------------------------------------------------------------------------------------
// Modules config — per-process ext.args and publishDir
// -------------------------------------------------------------------------------------
includeConfig 'conf/modules.config'

// -------------------------------------------------------------------------------------
// Process defaults
// -------------------------------------------------------------------------------------
process {
    // Default resource labels used by nf-core modules
    // process_single → 1 CPU, 6 GB RAM
    // process_medium → 6 CPUs, 36 GB RAM
    withLabel: 'process_single' {
        cpus   = 1
        memory = '6.GB'
        time   = '1.h'
    }
    withLabel: 'process_medium' {
        cpus   = { Math.min(6, params.max_cpus as int) }
        memory = { Math.min(36, params.max_memory.toGiga() as int).GB }
        time   = '1.h'
    }

    withName: 'FASTQC' {
        container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0'
    }
}

// -------------------------------------------------------------------------------------
// Profiles
// -------------------------------------------------------------------------------------
profiles {

    // Run with Docker (default for local development)
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        conda.enabled          = false
        singularity.enabled    = false
        apptainer.enabled      = false
    }

    // Run with Singularity (typical on HPC clusters)
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
        apptainer.enabled      = false
    }

    // Run with Apptainer (open-source Singularity fork, increasingly common on HPC)
    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
        conda.enabled          = false
        singularity.enabled    = false
    }

    // Run with Conda environments defined in each module's environment.yml
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
        apptainer.enabled      = false
    }

    // Test profile — uses small bundled data, fast for CI
    test {
        params.input  = "${projectDir}/assets/samplesheet.csv"
        params.outdir = "results_test"
    }

}

// -------------------------------------------------------------------------------------
// Execution reports
// -------------------------------------------------------------------------------------
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
