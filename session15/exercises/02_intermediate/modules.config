/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    exercises/02_intermediate/modules.config
    TASK: Fill in ext.args for FASTQC and MULTIQC
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    This config is passed to Nextflow via:  -c exercises/02_intermediate/modules.config

    Rules:
      - ext.args values should be CLOSURES (wrapped in { }) so they evaluate at runtime
      - For FASTQC: add --quiet to suppress progress messages
      - For MULTIQC: add a custom report title using --title "Session 15 QC Report"
      - For MULTIQC: set ext.prefix to control the output filename (no closure needed)
*/

process {

    withName: 'FASTQC' {
        ext.args = { '--quiet' }     // add --quiet
    }

    withName: 'MULTIQC' {
        ext.args   = { '--title "Session 15 QC Report"' }   // add --title "Session 15 QC Report"
        ext.prefix = { 'multiqc' }       // set output filename prefix (no closure needed here)
    }

}
